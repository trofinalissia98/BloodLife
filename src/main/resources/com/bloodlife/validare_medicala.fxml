<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<HBox prefHeight="750.0" prefWidth="1100.0" styleClass="dashboard-root"
      stylesheets="@style.css" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bloodlife.controller.MedicController">

    <VBox spacing="30" styleClass="sidebar" style="-fx-background-color: linear-gradient(to bottom, #2c3e50, #000000);">
        <padding><Insets top="50" left="25" right="25" bottom="30"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <StackPane styleClass="logo-icon-small" style="-fx-background-color: rgba(255,255,255,0.1);">
                <Label text="👨‍⚕️" style="-fx-font-size: 20px;"/>
            </StackPane>
            <Label text="BloodLife Pro" styleClass="sidebar-brand"/>
        </HBox>

        <Separator opacity="0.1" maxWidth="200"/>

        <VBox spacing="12" VBox.vgrow="ALWAYS">
            <Button text="📋  Programări Azi" maxWidth="Infinity" styleClass="nav-button-active" style="-fx-background-color: white; -fx-text-fill: #2c3e50;"/>
            <Button text="📦  Gestiune Stoc" onAction="#handleGoToStoc" maxWidth="Infinity" styleClass="nav-button"/>
            <Button text="📊  Statistici" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>

        <Button onAction="#handleLogout" text="🚪 Deconectare" maxWidth="Infinity" styleClass="logout-button"/>
    </VBox>

    <VBox spacing="30" HBox.hgrow="ALWAYS">
        <padding><Insets top="40" left="40" right="40" bottom="40"/></padding>

        <VBox spacing="5">
            <Label text="Validare Proces Donare" styleClass="header-title"/>
            <Label text="Confirmă prezența donatorului și înregistrează unitatea de sânge." styleClass="header-subtitle"/>
        </VBox>

        <HBox spacing="30" VBox.vgrow="ALWAYS">

            <VBox spacing="15" prefWidth="350" styleClass="info-card">
                <Label text="Donatori Programați" style="-fx-font-weight: bold; -fx-font-size: 16px;"/>
                <ListView fx:id="donatoriAziList" VBox.vgrow="ALWAYS" style="-fx-background-radius: 15; -fx-border-color: #eee; -fx-border-radius: 15;"/>
                <Button onAction="#handleIncarcaDonatori" text="🔄 Reîmprospătează Lista" maxWidth="Infinity" styleClass="text-button-red"/>
            </VBox>

            <VBox spacing="25" styleClass="info-card" HBox.hgrow="ALWAYS">
                <Label text="Fișă Recoltare Unitate" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

                <GridPane hgap="20" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>

                    <Label text="Cod Unic Pungă:" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
                    <TextField fx:id="codPungaField" promptText="Ex: BL-2026-0001" styleClass="modern-input" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Tip Recoltare:" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
                    <ComboBox fx:id="tipRecoltareCombo" maxWidth="Infinity" styleClass="modern-input" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Cantitate (ml):" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
                    <TextField fx:id="cantitateField" text="450" styleClass="modern-input" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Tensiune Arterială:" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
                    <HBox alignment="CENTER_LEFT" spacing="10" GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <TextField fx:id="tsField" prefWidth="80" promptText="Sistolică" styleClass="modern-input"/>
                        <Label text="/" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="tdField" prefWidth="80" promptText="Diastolică" styleClass="modern-input"/>
                        <Label text="mmHg" styleClass="card-unit"/>
                    </HBox>
                </GridPane>

                <VBox spacing="10" VBox.vgrow="ALWAYS">
                    <Label text="Observații Medicale / Motive Respingere:" styleClass="field-label"/>
                    <TextArea fx:id="observatiiField" promptText="Introduceți observațiile aici..." VBox.vgrow="ALWAYS"
                              style="-fx-background-color: #f1f2f6; -fx-background-radius: 15; -fx-border-color: transparent;"/>
                </VBox>

                <Separator />

                <HBox spacing="20" alignment="CENTER_RIGHT">
                    <Button onAction="#handleRespinge" text="❌ Respinge Donator"
                            style="-fx-background-color: #fab1a0; -fx-text-fill: #c0392b; -fx-background-radius: 15; -fx-padding: 12 25; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    <Button onAction="#handleFinalizeaza" text="✅ Finalizează Recoltarea"
                            styleClass="button-confirm-final" prefHeight="50" prefWidth="250"/>
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</HBox>