<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="750.0" prefWidth="1150.0" stylesheets="@style.css" styleClass="dashboard-root"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bloodlife.controller.AdminController">

    <VBox spacing="20" styleClass="sidebar">
        <padding><Insets top="40" left="20" right="20" bottom="20"/></padding>
        <Label text="🩸 BloodLife Admin" styleClass="sidebar-brand"/>
        <Separator opacity="0.3"/>

        <VBox spacing="10" VBox.vgrow="ALWAYS">
            <Button fx:id="btnDashboard" onAction="#showDashboardTab" text="📊 Tablou de Bord" maxWidth="Infinity" styleClass="nav-button-active"/>
            <Button fx:id="btnUsers" onAction="#showUsersTab" text="👥 Utilizatori &amp; Medici" maxWidth="Infinity" styleClass="nav-button"/>
            <Button fx:id="btnAlerts" onAction="#showAlertsTab" text="📢 Alerte Globale" maxWidth="Infinity" styleClass="nav-button"/>
        </VBox>

        <Separator opacity="0.1"/>
        <Button onAction="#handleLogout" text="🚪 Logout" maxWidth="Infinity" styleClass="logout-button"/>
    </VBox>

    <VBox HBox.hgrow="ALWAYS" spacing="0">
        <TabPane fx:id="mainTabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS"
                 styleClass="admin-tab-pane" style="-fx-tab-max-height: 0; -fx-tab-min-height: 0;">

            <Tab fx:id="tabDashboard">
                <content>
                    <fx:include source="statistici_admin.fxml"/>
                </content>
            </Tab>

            <Tab fx:id="tabUsers">
                <VBox spacing="30">
                    <padding><Insets top="40" left="40" right="40" bottom="40"/></padding>
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <VBox spacing="5">
                            <Label text="Lista Utilizatorilor" styleClass="header-title-light"/>
                            <Label text="Gestionează conturile medicilor și donatorilor din sistem." styleClass="header-subtitle-light"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button onAction="#handleAddMedic" text="+ Adaugă Medic Nou" styleClass="button-primary"/>
                    </HBox>

                    <TableView fx:id="utilizatoriTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
                        <columns>
                            <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                            <TableColumn fx:id="colNume" text="Nume Complet" prefWidth="250"/>
                            <TableColumn fx:id="colEmail" text="Email" prefWidth="250"/>
                            <TableColumn fx:id="colRol" text="Rol" prefWidth="150"/>
                        </columns>
                    </TableView>

                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button onAction="#handleDeactivateUser" text="Dezactivează Cont"
                                style="-fx-background-color: #fab1a0; -fx-text-fill: #c0392b; -fx-background-radius: 12; -fx-padding: 10 20; -fx-font-weight: bold;"/>
                        <Button onAction="#handleResetPassword" text="Resetează Parolă" styleClass="button-primary" style="-fx-background-color: #636e72;"/>
                    </HBox>
                </VBox>
            </Tab>

            <Tab fx:id="tabAlerts">
                <VBox spacing="30">
                    <padding><Insets top="40" left="40" right="40" bottom="40"/></padding>
                    <VBox spacing="5">
                        <Label text="Emitere Alertă Globală" styleClass="header-title-light"/>
                        <Label text="Trimite o notificare urgentă către toți donatorii compatibili." styleClass="header-subtitle-light"/>
                    </VBox>

                    <VBox styleClass="info-card" spacing="25">
                        <GridPane hgap="20" vgap="20">
                            <Label text="Grupă Sânge Target:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="adminAlertGrupa" prefWidth="200" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="modern-input"/>

                            <Label text="RH:" GridPane.rowIndex="0" GridPane.columnIndex="2" style="-fx-font-weight: bold;"/>
                            <ComboBox fx:id="adminAlertRh" prefWidth="120" GridPane.rowIndex="0" GridPane.columnIndex="3" styleClass="modern-input"/>

                            <Label text="Mesaj Alertă:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                            <TextArea fx:id="adminAlertMesaj" prefHeight="150" promptText="Scrie aici mesajul care va apărea pe dashboard-ul donatorilor..."
                                      GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="3" styleClass="modern-input" style="-fx-background-radius: 15;"/>
                        </GridPane>
                        <Button text="🚀 Emite Alertă către toți donatorii compatibili" onAction="#handleAdminAlerta"
                                maxWidth="Infinity" styleClass="button-primary" style="-fx-font-size: 16px; -fx-padding: 15;"/>
                    </VBox>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</HBox>