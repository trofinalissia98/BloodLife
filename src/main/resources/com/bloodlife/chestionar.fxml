<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="750.0" prefWidth="900.0" styleClass="dashboard-root"
           stylesheets="@style.css" xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bloodlife.controller.ChestionarController">

    <AnchorPane mouseTransparent="true">
        <Circle fill="#b22222" radius="150.0" layoutX="850.0" layoutY="50.0" opacity="0.03"/>
    </AnchorPane>

    <VBox alignment="TOP_CENTER" spacing="25.0">
        <padding>
            <Insets top="40" left="60" right="60" bottom="40"/>
        </padding>

        <VBox alignment="CENTER" spacing="10">
            <Label text="Verificare Eligibilitate" styleClass="header-title"/>
            <Label text="Siguranța donării este prioritatea noastră. Te rugăm să completezi datele de mai jos."
                   styleClass="header-subtitle" wrapText="true" textAlignment="CENTER" maxWidth="600"/>
        </VBox>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="modern-scroll-pane">
            <content>
                <VBox fx:id="questionsContainer" spacing="15" styleClass="questions-grid">
                    <padding>
                        <Insets top="10" left="10" right="15" bottom="10"/>
                    </padding>
                </VBox>
            </content>
        </ScrollPane>

        <VBox spacing="20" alignment="CENTER" styleClass="footer-container">
            <Label fx:id="resultLabel" styleClass="result-label" wrapText="true" textAlignment="CENTER"/>

            <HBox spacing="25" alignment="CENTER">
                <Button text="Anulează" onAction="#handleCancel" styleClass="text-button-muted"/>
                <Button text="Validează Chestionarul" onAction="#handleValidare"
                        styleClass="button-primary-large"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>