<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.shape.SVGPath?>

<StackPane prefHeight="750.0" prefWidth="1100.0" stylesheets="@style.css"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.bloodlife.controller.DashboardController">

    <HBox styleClass="dashboard-root">
        <VBox spacing="30" styleClass="sidebar">
            <padding><Insets top="50" left="25" right="25" bottom="30"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="15">
                <StackPane styleClass="logo-icon-small">
                    <SVGPath content="M15 6C15 6 9.00001 13 9.00001 17C9.00001 20.3137 11.6863 23 15 23C18.3137 23 21 20.3137 21 17C21 13 15 6 15 6Z"
                             fill="white" scaleX="1.2" scaleY="1.2" />
                </StackPane>
                <Label text="BloodLife" styleClass="sidebar-brand"/>
            </HBox>

            <Separator opacity="0.1" maxWidth="200"/>

            <VBox spacing="12" VBox.vgrow="ALWAYS">
                <Button text="🏠  Profilul Meu" maxWidth="Infinity" styleClass="nav-button-active"/>
                <Button onAction="#handleProgramareNoua" text="📅  Programare Nouă" maxWidth="Infinity" styleClass="nav-button"/>
                <Button onAction="#handleIstoric" text="📜  Istoric Donări" maxWidth="Infinity" styleClass="nav-button"/>
                <Button onAction="#handleVeziCentre" text="🏥  Centre Disponibile" maxWidth="Infinity" styleClass="nav-button"/>
            </VBox>

            <VBox spacing="15">
                <Separator opacity="0.1"/>
                <Button onAction="#handleLogout" text="🚪 Deconectare" maxWidth="Infinity" styleClass="logout-button"/>
            </VBox>
        </VBox>

        <VBox spacing="35" HBox.hgrow="ALWAYS" styleClass="content-area">
            <padding><Insets top="50" left="60" right="60" bottom="50"/></padding>

            <HBox alignment="CENTER_LEFT">
                <VBox spacing="5">
                    <Label fx:id="welcomeLabel" text="Bună, Ion!" styleClass="header-title-light"/>
                    <Label fx:id="urgentaLabel" visible="false" managed="false" wrapText="true" maxWidth="Infinity" />
                    <Label text="Sângele tău poate salva până la 3 vieți astăzi." styleClass="header-subtitle-light"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Circle fill="#f1f2f6" radius="25" stroke="#dfe6e9" opacity="0.2"/>
            </HBox>

            <HBox spacing="25">
                <VBox styleClass="info-card, card-blood" HBox.hgrow="ALWAYS">
                    <Label text="GRUPĂ SANGUINĂ" styleClass="card-label"/>
                    <Label fx:id="grupaLabel" text="B+" styleClass="card-value-large"/>
                </VBox>

                <VBox styleClass="info-card" HBox.hgrow="ALWAYS">
                    <Label text="GREUTATE" styleClass="card-label"/>
                    <HBox alignment="BASELINE_LEFT" spacing="5">
                        <Label fx:id="greutateLabel" text="75" styleClass="card-value"/>
                        <Label text="kg" styleClass="card-unit"/>
                    </HBox>
                </VBox>

                <VBox styleClass="info-card" HBox.hgrow="ALWAYS">
                    <Label text="STATUS ACTUAL" styleClass="card-label"/>
                    <Label fx:id="statusLabel" text="ELIGIBIL" styleClass="card-value-status"/>
                </VBox>
            </HBox>

            <VBox spacing="20" styleClass="activity-container-light">
                <HBox alignment="CENTER_LEFT">
                    <Label text="Programări Viitoare" styleClass="section-title-light"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <StackPane>
                    <VBox fx:id="noProgramareLabel" alignment="CENTER" spacing="10" visible="false" managed="false"
                          style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 30; -fx-border-color: rgba(255,255,255,0.2); -fx-border-style: dashed; -fx-border-radius: 15;">
                        <Label text="📭" style="-fx-font-size: 30px;"/>
                        <Label text="Nu ai nicio programare activă în acest moment." style="-fx-text-fill: white;"/>
                        <Button onAction="#handleProgramareNoua" text="Programează-te acum" styleClass="text-button-red-light"/>
                    </VBox>

                    <VBox fx:id="programareActivaBox" spacing="15" visible="false" managed="false" styleClass="appointment-main-card">
                        <HBox spacing="20" alignment="CENTER_LEFT">
                            <VBox alignment="CENTER" styleClass="calendar-badge">
                                <Label text="DATA" styleClass="calendar-month"/>
                                <Label fx:id="ziuaLabel" text="25" styleClass="calendar-day"/>
                            </VBox>

                            <VBox spacing="5" HBox.hgrow="ALWAYS">
                                <Label fx:id="centruLabel" text="Centrul de Transfuzie Sanguină" styleClass="appointment-title"/>
                                <HBox spacing="15">
                                    <Label fx:id="oraLabel" text="🕒 09:30" styleClass="appointment-subinfo"/>
                                    <Label text="📍 Locație confirmată" styleClass="appointment-subinfo"/>
                                </HBox>
                            </VBox>

                            <VBox alignment="CENTER_RIGHT" spacing="10">
                                <Button onAction="#handleAnuleazaProgramare" text="Anulează" styleClass="btn-cancel-small"/>
                                <Button onAction="#handleModificaProgramare" text="Modifică ora" styleClass="btn-edit-small"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </StackPane>
            </VBox>
        </VBox>
    </HBox>
    <VBox fx:id="chatWindow" visible="false" managed="false"
          maxWidth="350" maxHeight="500" spacing="10"
          StackPane.alignment="BOTTOM_RIGHT"
          styleClass="chat-window-premium">

        <StackPane.margin>
            <Insets bottom="100.0" right="30.0" />
        </StackPane.margin>

        <effect>
            <DropShadow color="#00000044" radius="30" />
        </effect>

        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 10 0; -fx-border-color: rgba(0,0,0,0.05); -fx-border-width: 0 0 1 0;">
            <SVGPath content="M15 6C15 6 9.00001 13 9.00001 17C9.00001 20.3137 11.6863 23 15 23C18.3137 23 21 20.3137 21 17C21 13 15 6 15 6Z"
                     fill="#ff4757" scaleX="1.2" scaleY="1.2" />
            <Label text="Bloodie AI Assistant" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#handleToggleChat" text="✕" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #b2bec3; -fx-font-size: 16px;"/>
        </HBox>

        <ScrollPane fx:id="chatScroll" fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <VBox fx:id="messageContainer" spacing="12" style="-fx-padding: 5;"/>
        </ScrollPane>

        <HBox spacing="8" style="-fx-padding: 5 0 0 0;">
            <TextField fx:id="chatInputField" onAction="#handleSendMessage" promptText="Scrie aici..." HBox.hgrow="ALWAYS"
                       styleClass="modern-input"/>
            <Button onAction="#handleSendMessage" text="➤"
                    style="-fx-background-color: #ff4757; -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 40; -fx-min-height: 40; -fx-cursor: hand;"/>
        </HBox>
    </VBox>

    <Button fx:id="btnChat" onAction="#handleToggleChat" text="💬"
            StackPane.alignment="BOTTOM_RIGHT"
            style="-fx-background-radius: 50; -fx-min-width: 65; -fx-min-height: 65; -fx-background-color: #ff4757; -fx-text-fill: white; -fx-font-size: 26px; -fx-cursor: hand;">
        <StackPane.margin>
            <Insets bottom="25.0" right="30.0" />
        </StackPane.margin>
        <effect>
            <DropShadow color="#ff475766" radius="15" />
        </effect>
    </Button>
</StackPane>