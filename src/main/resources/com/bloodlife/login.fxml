<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<StackPane fx:id="mainLoginRoot" prefHeight="700.0" prefWidth="1000.0" styleClass="login-root"
           stylesheets="@style.css" xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bloodlife.controller.LoginController">

    <!-- Fundal cu forme geometrice -->
    <AnchorPane mouseTransparent="true">
        <Circle fill="#ff4757" radius="350.0" layoutX="1000.0" layoutY="100.0" opacity="0.15"/>
        <Circle fill="#ff4757" radius="250.0" layoutX="0.0" layoutY="700.0" opacity="0.15"/>
        <Circle fill="white" radius="150.0" layoutX="900.0" layoutY="600.0" opacity="0.05"/>
    </AnchorPane>

    <VBox fx:id="loginCard" alignment="CENTER" spacing="35.0" maxWidth="480" maxHeight="650"
          styleClass="login-card">
        <padding>
            <Insets bottom="60.0" left="60.0" right="60.0" top="60.0"/>
        </padding>

        <VBox alignment="CENTER" spacing="20">
            <StackPane styleClass="logo-container">
                <SVGPath content="M15 6C15 6 9.00001 13 9.00001 17C9.00001 20.3137 11.6863 23 15 23C18.3137 23 21 20.3137 21 17C21 13 15 6 15 6Z"
                         fill="#ff4757" scaleX="4.5" scaleY="4.5" />
            </StackPane>

            <VBox alignment="CENTER" spacing="10">
                <Label text="BloodLife" styleClass="brand-title"/>
                <Label text="Puterea de a salva este în tine" styleClass="subtitle-label"/>
            </VBox>
        </VBox>

        <VBox spacing="25.0">
            <VBox spacing="10">
                <Label text="ADRESA DE EMAIL" styleClass="field-label" style="-fx-font-weight: 900; -fx-character-spacing: 1px; -fx-font-size: 12px;"/>
                <TextField fx:id="emailField" promptText="exemplu@mail.com" styleClass="modern-input" prefHeight="55.0"/>
            </VBox>
            <VBox spacing="10">
                <Label text="PAROLA" styleClass="field-label" style="-fx-font-weight: 900; -fx-character-spacing: 1px; -fx-font-size: 12px;"/>
                <PasswordField fx:id="parolaField" promptText="••••••••" styleClass="modern-input" prefHeight="55.0"/>
            </VBox>
        </VBox>

        <VBox spacing="25" alignment="CENTER">
            <Button onAction="#handleLogin" prefHeight="65.0" maxWidth="Infinity"
                    text="CONECTARE" styleClass="button-login"/>

            <HBox alignment="CENTER" spacing="10">
                <Label text="Nu ai un cont?" style="-fx-text-fill: #636e72;"/>
                <Hyperlink onAction="#handleGoToRegister" text="Creează cont nou"
                           styleClass="modern-hyperlink" style="-fx-font-size: 14px;"/>
            </HBox>
        </VBox>

        <Label fx:id="statusLabel" styleClass="error-label" wrapText="true" textAlignment="CENTER"/>
    </VBox>
</StackPane>