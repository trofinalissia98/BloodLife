<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="25" styleClass="dashboard-root" stylesheets="@style.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.bloodlife.controller.StocController">

    <padding><Insets top="40" left="40" right="40" bottom="40"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox spacing="5">
            <Label text="📦 Gestiune Stoc Sânge" styleClass="header-title-light"/>
            <Label text="Vizualizează și gestionează unitățile de sânge disponibile." styleClass="header-subtitle-light"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="⬅ Înapoi la Validare" onAction="#handleInapoi" styleClass="btn-cancel-small"
                style="-fx-text-fill: white; -fx-border-color: white;"/>
    </HBox>

    <HBox spacing="15" alignment="CENTER_LEFT" styleClass="info-card">
        <Label text="Filtrează după:" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
        <ComboBox fx:id="filterTipCombo" promptText="Tip Recoltare" prefWidth="150" styleClass="modern-input"/>
        <ComboBox fx:id="filterGrupaCombo" promptText="Grupă Sanguină" prefWidth="150" styleClass="modern-input"/>
        <Button text="🔍 Filtrează" onAction="#handleFilter" styleClass="button-primary"/>
        <Button text="🔄 Reset" onAction="#incarcaDatele" styleClass="button-primary" style="-fx-background-color: #636e72;"/>
    </HBox>

    <VBox spacing="15" styleClass="info-card" style="-fx-border-color: #ff7675; -fx-border-width: 0 0 0 5;">
        <Label text="📢 Emite Alertă Urgentă" style="-fx-font-weight: bold; -fx-text-fill: #d63031; -fx-font-size: 16px;"/>
        <HBox spacing="15" alignment="CENTER_LEFT">
            <ComboBox fx:id="alertGrupaCombo" promptText="Grupa" prefWidth="100" styleClass="modern-input"/>
            <ComboBox fx:id="alertRhCombo" promptText="RH" prefWidth="80" styleClass="modern-input"/>
            <TextField fx:id="alertMesajField" promptText="Scrie aici mesajul de urgență..." HBox.hgrow="ALWAYS" styleClass="modern-input"/>
            <Button text="🚀 Trimite Alerte" onAction="#handleTrimiteAlerta" styleClass="button-primary"/>
        </HBox>
    </VBox>

    <TableView fx:id="stocTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="colCod" text="Cod Unitate" prefWidth="150"/>
            <TableColumn fx:id="colTip" text="Tip" prefWidth="120"/>
            <TableColumn fx:id="colGrupa" text="Grupă" prefWidth="80"/>
            <TableColumn fx:id="colRh" text="RH" prefWidth="60"/>
            <TableColumn fx:id="colCantitate" text="Cantitate (ml)" prefWidth="100"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
            <TableColumn fx:id="colData" text="Data Recoltării" prefWidth="180"/>
        </columns>
    </TableView>

    <HBox spacing="15" alignment="CENTER_RIGHT" styleClass="info-card">
        <Label text="Acțiuni unitate selectată:" style="-fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
        <Button text="⚠️ Marcare EXPIRAT" onAction="#handleMarkExpirat"
                style="-fx-background-color: #fab1a0; -fx-text-fill: #c0392b; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;"/>
        <Button text="🔒 Rezervă" onAction="#handleMarkRezervat"
                style="-fx-background-color: #81ecec; -fx-text-fill: #00818a; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;"/>
        <Button text="✅ Marcare UTILIZAT" onAction="#handleMarkUtilizat"
                styleClass="button-primary" style="-fx-padding: 10 20;"/>
    </HBox>
</VBox>